# NutriSmart Advanced Features Configuration
# Copy this file to .env and fill in your actual values

# Groq API Configuration (REQUIRED)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# YouTube API Configuration (OPTIONAL)
# Get your API key at: https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key-here

# Database Configuration
DB_HOST=127.0.0.1
DB_NAME=nutrismart
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads/food-images/

# Application Settings
APP_TIMEZONE=Africa/Tunis
APP_ENV=development

# Barcode API (No key needed - uses OpenFoodFacts)
BARCODE_API_URL=https://world.openfoodfacts.org/api/v0/product/
