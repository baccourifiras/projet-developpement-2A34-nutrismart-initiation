*.sql.backup
*.sql.gz
database/backups/

# Composer (if used)
vendor/
composer.lock

# Node Modules (if used)
node_modules/
package-lock.json

# Build Files
dist/
build/

# OS Files
Thumbs.db
.DS_Store
desktop.ini

# PHP
*.cache
.phpunit.result.cache

# Sensitive Data
api_keys.txt
credentials.txt
secrets.txt
